# =============================================================================
# Innovation Intelligence Copilot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL + pgvector
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/innovation_copilot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/innovation_copilot

# -----------------------------------------------------------------------------
# Neo4j Knowledge Graph
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# -----------------------------------------------------------------------------
# Redis (caching + task queue)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default LLM provider: "anthropic" or "openai"
DEFAULT_LLM_PROVIDER=anthropic

# Default models
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=generate-with-openssl-rand-base64-32
API_KEY_SALT=generate-a-random-salt-value

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# Ingestion (optional — for data source connectors)
# -----------------------------------------------------------------------------
# ARXIV_API_URL=http://export.arxiv.org/api/query
# NEWS_API_KEY=your_news_api_key
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
