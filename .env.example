# =============================================================================
# Innovation Intelligence Copilot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL + pgvector
# -----------------------------------------------------------------------------
# Local development:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/innovation_copilot
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/innovation_copilot
# Neon (production) — use pooled connection string from Neon dashboard:
# DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/innovation_copilot?sslmode=require
# DATABASE_URL_SYNC=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/innovation_copilot?sslmode=require

# -----------------------------------------------------------------------------
# Neo4j Knowledge Graph
# -----------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password

# -----------------------------------------------------------------------------
# Redis (caching + task queue)
# -----------------------------------------------------------------------------
# Local development:
REDIS_URL=redis://localhost:6379/0
# Upstash (production) — use REST URL from Upstash console:
# REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6379

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default LLM provider: "anthropic" or "openai"
DEFAULT_LLM_PROVIDER=anthropic

# Default models
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Per-role analysis models (cost/quality tuning)
AGENT_MODEL=claude-haiku-4-5         # extraction agents (cheap)
EXECUTIVE_MODEL=claude-sonnet-4-6    # final synthesis (quality)
WEB_SEARCH_MODEL=claude-sonnet-4-6   # web retrieval (dynamic-filtering tools)

# Retrieval / grounding
# Live web search (Anthropic server-side web_search/web_fetch) for real-time
# citations. Bills per search AND pulls fetched pages in as input tokens — the
# dominant cost of an analysis. Keep the cap low. false = documents-only.
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=2

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
SECRET_KEY=generate-with-openssl-rand-base64-32
API_KEY_SALT=generate-a-random-salt-value

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# -----------------------------------------------------------------------------
# NextAuth.js (Google OAuth)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
# Set to your deployed frontend URL in production (e.g. https://your-app.vercel.app)
NEXTAUTH_URL=http://localhost:3000
# Google OAuth credentials — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# -----------------------------------------------------------------------------
# Ingestion (optional — for data source connectors)
# -----------------------------------------------------------------------------
# ARXIV_API_URL=http://export.arxiv.org/api/query
# NEWS_API_KEY=your_news_api_key
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
